/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "navihive",
    "main": "worker/index.ts",
    "compatibility_date": "2025-04-05",
    "compatibility_flags": ["nodejs_compat"],  // 必须启用 Node.js 兼容
    "assets": {
        "not_found_handling": "single-page-application"
    },
    "observability": {
        "enabled": true
    },
    // D1数据库绑定
    "d1_databases": [
        {
            "binding": "DB",
            "database_name": "navihive-db",
            "database_id": "1a40b86b-a9e8-419f-9482-c3084d621ed3"
        }
    ],
    "vars": {
        "AUTH_ENABLED": "true",
        "AUTH_USERNAME": "lonk",
        "AUTH_PASSWORD": "$2a$10$Zca9gSkj.1XvR2FD9zVQnO2wwHch9cTZClaIge.da98718VUv2rTu",
        "AUTH_SECRET": "$2a$10$Zca9gSkj.1XvR2FD9zVQnO2wwHch9cTZClaIge.da98718VUv2rTu"
    }
}




